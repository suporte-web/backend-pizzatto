generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Assinatura {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome          String
  telefone      String?
  email         String
  criadoPor     String
  caminhoImagem String?
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  updatedAt     DateTime @default(now()) @db.Timestamp(6)
  status        String?  @default("AGUARDANDO APROVAÇÃO")
  motivo        String?
  departamento  String
}

model ContasOffice {
  id    String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome  String
  email String
  senha String
  ativo Boolean @default(false)
}

model InventarioImpressoras {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  filial             String
  marca              String
  modelo             String
  numeroSerie        String?
  ip                 String
  macLan             String
  macWlan            String?
  localizacao        String?
  senhaAdministrador String?
  etiqueta           String?
  createdAt          DateTime @default(now()) @db.Timestamp(6)
  updatedAt          DateTime @default(now()) @db.Timestamp(6)
}

model Mural {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo              String
  mensagem            String
  caminhoImagem       String?
  filiais             String[]
  createdAt           DateTime           @default(now()) @db.Timestamp(6)
  updatedAt           DateTime           @default(now()) @db.Timestamp(6)
  ativo               Boolean            @default(true)
  validoAte           String?
  criadoPor           String
  importante          Boolean            @default(false)
  departamentoCriador String?
  tipoMidia           String?
  youtubeId           String?
  youtubeUrl          String?
  blur                Boolean            @default(false)
  MuralComentario     MuralComentario[]
  MuralLike           MuralLike[]
  MuralVisualizado    MuralVisualizado[]
}

model Pops {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  filename     String
  originalName String
  mimetype     String
  size         String
  filePath     String
  folder       String
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @db.Timestamp(6)
  criadoPor    String?
  departamento String?
}

model ToDo {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome           String
  descricao      String
  prazoLimite    String?
  responsavel    String
  finalizado     Boolean  @default(false)
  dataFinalizado String?
  createdAt      DateTime @default(now()) @db.Timestamp(6)
  updatedAt      DateTime @default(now()) @db.Timestamp(6)
}

model audit_logs {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  acao           String
  entidade       String
  ipAddress      String?
  filialEntidade String?
  createdAt      DateTime @default(now())
}

model PlantaoConfig {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime        @default(now()) @db.Timestamp(6)
  updatedAt      DateTime        @default(now()) @db.Timestamp(6)
  dataJanela     String?
  janelaFim      String
  janelaInicio   String
  plantonistaId  String?         @db.Uuid
  status         String
  diaSemana      Int?
  deletedAt      DateTime?
  deletedBy      String?
  fimPlantao     DateTime?
  inicioPlantao  DateTime?
  PlantaoContato PlantaoContato? @relation(fields: [plantonistaId], references: [id])
}

model PlantaoContato {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome          String
  telefone      String
  area          Area
  createdAt     DateTime        @default(now()) @db.Timestamp(6)
  updatedAt     DateTime        @default(now()) @db.Timestamp(6)
  PlantaoConfig PlantaoConfig[]
}

model AssinaturaPadrao {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caminhoBackground    String?
  criadoPor            String?
  isAtual              Boolean  @default(true)
  createdAt            DateTime @default(now()) @db.Timestamp(6)
  updatedAt            DateTime @default(now()) @db.Timestamp(6)
  departamentoX        Int?
  departamentoY        Int?
  logoHeight           Int?
  logoX                Int?
  logoY                Int?
  nomeX                Int?
  nomeY                Int?
  photoSize            Int?
  photoX               Int?
  photoY               Int?
  telefoneX            Int?
  telefoneY            Int?
  departamentoCorFont  String?
  departamentoFontSize String?
  nomeCorFont          String?
  nomeFontSize         String?
  telefoneCorFont      String?
  telefoneFontSize     String?
}

model Calendario {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome          String
  data          String
  horario       String
  local         String?
  criadoPor     String?
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  updatedAt     DateTime @default(now()) @db.Timestamp(6)
  descricao     String?
  colaboradores String[]
}

model PoliticaAceites {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  colaborador String
  dataAceite  DateTime  @default(now())
  politicaId  String    @db.Uuid
  createdAt   DateTime  @default(now())
  Politicas   Politicas @relation(fields: [politicaId], references: [id])
}

model Politicas {
  id                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caminhoArquivo       String?
  nome                 String
  descricao            String
  responsavel          String
  dataUpload           String?
  criadoPor            String?
  ativo                Boolean           @default(true)
  liberadoVisualizacao Boolean           @default(false)
  createdAt            DateTime          @default(now()) @db.Timestamp(6)
  updatedAt            DateTime          @default(now()) @db.Timestamp(6)
  departamento         String
  tipoPolitica         String
  versao               String            @default("1")
  PoliticaAceites      PoliticaAceites[]
}

model MuralComentario {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  muralId      String   @db.Uuid
  codigo       String
  nome         String
  comentario   String
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @db.Timestamp(6)
  adObjectGuid String?
  Mural        Mural    @relation(fields: [muralId], references: [id], onDelete: Cascade)

  @@index([muralId])
}

model MuralLike {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  muralId      String   @db.Uuid
  codigo       String
  nome         String
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  adObjectGuid String?
  Mural        Mural    @relation(fields: [muralId], references: [id], onDelete: Cascade)

  @@unique([muralId, codigo])
  @@index([muralId])
}

model PaginaInstitucional {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo          String
  descricao       String
  dataAtualizacao String
  createdAt       DateTime @default(now()) @db.Timestamp(6)
  updatedAt       DateTime @default(now()) @db.Timestamp(6)
  status          Boolean  @default(true)
  arquivos        Json[]   @default([])
}

model BibliotecaMarca {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome      String
  status    Boolean  @default(true)
  descricao String
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @db.Timestamp(6)
  arquivos  Json[]   @default([])
}

model Conversa {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipo                 TipoConversa
  nome                 String?
  chaveDireta          String?                @unique
  criadoPorId          String                 @db.Uuid
  ultimaMensagemEm     DateTime?
  createdAt            DateTime               @default(now()) @db.Timestamp(6)
  updatedAt            DateTime               @default(now()) @db.Timestamp(6)
  UsuarioChat          UsuarioChat            @relation(fields: [criadoPorId], references: [id])
  Mensagem             Mensagem[]
  ParticipanteConversa ParticipanteConversa[]

  @@index([criadoPorId])
  @@index([tipo])
  @@index([ultimaMensagemEm])
}

model Mensagem {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversaId   String       @db.Uuid
  remetenteId  String       @db.Uuid
  conteudo     String?
  createdAt    DateTime     @default(now()) @db.Timestamp(6)
  deletedAt    DateTime?
  updatedAt    DateTime     @default(now()) @db.Timestamp(6)
  arquivoUrl   String?
  mimeType     String?
  nomeArquivo  String?
  tamanhoBytes Int?
  tipo         TipoMensagem @default(TEXTO)
  nomeSalvo    String?
  Conversa     Conversa     @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  UsuarioChat  UsuarioChat  @relation(fields: [remetenteId], references: [id])

  @@index([remetenteId])
  @@index([conversaId, createdAt])
}

model ParticipanteConversa {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversaId      String      @db.Uuid
  usuarioId       String      @db.Uuid
  entrouEm        DateTime    @default(now())
  ultimaLeituraEm DateTime?
  admin           Boolean     @default(false)
  createdAt       DateTime    @default(now()) @db.Timestamp(6)
  updatedAt       DateTime    @default(now()) @db.Timestamp(6)
  Conversa        Conversa    @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  UsuarioChat     UsuarioChat @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([conversaId, usuarioId])
  @@index([conversaId])
  @@index([usuarioId])
}

model UsuarioChat {
  id                                     String                                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adObjectGuid                           String                                   @unique
  usuario                                String
  nome                                   String
  email                                  String?
  empresa                                String?
  departamento                           String?
  telefone                               String?
  ativo                                  Boolean                                  @default(true)
  createdAt                              DateTime                                 @default(now()) @db.Timestamp(6)
  updatedAt                              DateTime                                 @default(now()) @db.Timestamp(6)
  Conversa                               Conversa[]
  DashboardAcesso                        DashboardAcesso[]
  Mensagem                               Mensagem[]
  ParticipanteConversa                   ParticipanteConversa[]
  RecrutamentoInternoCandidato           RecrutamentoInternoCandidato[]
  RecrutamentoInternoCandidatoObservacao RecrutamentoInternoCandidatoObservacao[]

  @@index([email])
  @@index([nome])
  @@index([usuario])
}

model DashboardAcesso {
  id                      String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adObjectGuid            String
  usuario                 String?
  nome                    String?
  email                   String?
  departamento            String?
  empresa                 String?
  ipAddress               String?
  userAgent               String?
  createdAt               DateTime    @default(now()) @db.Timestamp(6)
  dataHoraSaida           DateTime?   @db.Timestamp(6)
  dataHoraUltimaAtividade DateTime?   @db.Timestamp(6)
  UsuarioChat             UsuarioChat @relation(fields: [adObjectGuid], references: [adObjectGuid])

  @@index([adObjectGuid])
  @@index([createdAt])
  @@index([dataHoraUltimaAtividade])
}

model LinksAcesso {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo    String
  descricao String
  tipoLink  String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @db.Timestamp(6)
  link      String
}

model Missao {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo                String
  descricao             String       @default("")
  tipo                  TipoMissao
  status                StatusMissao @default(RASCUNHO)
  pontos                Int          @default(10)
  minimoEvidencias      Int          @default(1)
  observacaoObrigatoria Boolean      @default(false)
  expiraEm              DateTime     @db.Timestamp(6)
  agendadaPara          DateTime?    @db.Timestamp(6)
  criadoPor             String?
  criadoPorSam          String?
  criadoPorAdObjectGuid String?
  preRequisitoMissaoId  String?      @db.Uuid
  createdAt             DateTime     @default(now()) @db.Timestamp(6)
  updatedAt             DateTime     @default(now()) @db.Timestamp(6)
  linkAcesso            String?
  Missao                Missao?      @relation("MissaoToMissao", fields: [preRequisitoMissaoId], references: [id])
  other_Missao          Missao[]     @relation("MissaoToMissao")
  Submissao             Submissao[]

  @@index([agendadaPara])
  @@index([preRequisitoMissaoId])
  @@index([status, expiraEm])
  @@index([tipo])
}

model MuralVisualizado {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  muralId      String   @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  adObjectGuid String?
  codigo       String?
  nome         String?
  Mural        Mural    @relation(fields: [muralId], references: [id], onDelete: Cascade)
}

model Submissao {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  missaoId            String                @db.Uuid
  usuarioAdObjectGuid String
  usuarioSam          String?
  usuarioNome         String?
  observacao          String                @default("")
  status              StatusSubmissao       @default(APROVADA)
  enviadaEm           DateTime              @default(now()) @db.Timestamp(6)
  revisadaPor         String?
  motivoRevisao       String?
  revisadaEm          DateTime?             @db.Timestamp(6)
  createdAt           DateTime              @default(now()) @db.Timestamp(6)
  updatedAt           DateTime              @default(now()) @db.Timestamp(6)
  Missao              Missao                @relation(fields: [missaoId], references: [id], onDelete: Cascade)
  SubmissaoComentario SubmissaoComentario[]
  SubmissaoDenuncia   SubmissaoDenuncia[]
  SubmissaoFoto       SubmissaoFoto[]
  SubmissaoReacao     SubmissaoReacao[]

  @@index([enviadaEm])
  @@index([missaoId, status])
  @@index([usuarioAdObjectGuid, status])
}

model SubmissaoComentario {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submissaoId         String    @db.Uuid
  usuarioAdObjectGuid String
  usuarioSam          String?
  usuarioNome         String?
  comentario          String
  deletedAt           DateTime? @db.Timestamp(6)
  createdAt           DateTime  @default(now()) @db.Timestamp(6)
  Submissao           Submissao @relation(fields: [submissaoId], references: [id], onDelete: Cascade)

  @@index([submissaoId, createdAt])
  @@index([usuarioAdObjectGuid])
}

model SubmissaoDenuncia {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submissaoId         String    @db.Uuid
  usuarioAdObjectGuid String
  usuarioSam          String?
  usuarioNome         String?
  motivo              String
  detalhes            String?
  resolvidaPor        String?
  resolvidaPorSam     String?
  resolvidaEm         DateTime? @db.Timestamp(6)
  createdAt           DateTime  @default(now()) @db.Timestamp(6)
  Submissao           Submissao @relation(fields: [submissaoId], references: [id], onDelete: Cascade)

  @@unique([submissaoId, usuarioAdObjectGuid])
  @@index([createdAt])
  @@index([submissaoId, resolvidaEm])
}

model SubmissaoFoto {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submissaoId    String    @db.Uuid
  caminhoArquivo String
  nomeArquivo    String
  originalName   String?
  mimetype       String?
  tamanhoBytes   Int?
  posicao        Int       @default(0)
  createdAt      DateTime  @default(now()) @db.Timestamp(6)
  Submissao      Submissao @relation(fields: [submissaoId], references: [id], onDelete: Cascade)

  @@index([submissaoId])
}

model SubmissaoReacao {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submissaoId         String    @db.Uuid
  usuarioAdObjectGuid String
  usuarioSam          String?
  usuarioNome         String?
  emoji               String
  createdAt           DateTime  @default(now()) @db.Timestamp(6)
  Submissao           Submissao @relation(fields: [submissaoId], references: [id], onDelete: Cascade)

  @@unique([submissaoId, usuarioAdObjectGuid, emoji])
  @@index([submissaoId])
  @@index([usuarioAdObjectGuid])
}

model RecrutamentoInterno {
  id                           String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vaga                         String
  descricao                    String?
  requisitos                   String?
  diferenciais                 String?
  departamento                 String?
  filial                       String?
  modalidade                   String?
  senioridade                  String?
  quantidadeVagas              Int?                           @default(1)
  dataLimite                   DateTime?
  dataInicio                   DateTime?
  gestorResponsavel            String?
  emailContato                 String?
  ativo                        Boolean                        @default(true)
  createdAt                    DateTime                       @default(now()) @db.Timestamp(6)
  updatedAt                    DateTime                       @default(now()) @db.Timestamp(6)
  beneficios                   String?
  horario                      String?
  RecrutamentoInternoCandidato RecrutamentoInternoCandidato[]
}

model RecrutamentoInternoCandidato {
  id                                     String                                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recrutamentoId                         String                                   @db.Uuid
  colaboradorId                          String                                   @db.Uuid
  status                                 String                                   @default("PENDENTE")
  createdAt                              DateTime                                 @default(now()) @db.Timestamp(6)
  updatedAt                              DateTime                                 @default(now()) @db.Timestamp(6)
  dataEntrevista                         String?
  curriculo                              Json?
  resumoProfissional                     String?
  motivoReprovacao                       String?
  UsuarioChat                            UsuarioChat                              @relation(fields: [colaboradorId], references: [id])
  RecrutamentoInterno                    RecrutamentoInterno                      @relation(fields: [recrutamentoId], references: [id])
  RecrutamentoInternoCandidatoObservacao RecrutamentoInternoCandidatoObservacao[]

  @@unique([recrutamentoId, colaboradorId])
}

model RecrutamentoInternoCandidatoObservacao {
  id                           String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidaturaId                String                       @db.Uuid
  observacao                   String
  createdAt                    DateTime                     @default(now()) @db.Timestamp(6)
  criadoPorId                  String                       @db.Uuid
  RecrutamentoInternoCandidato RecrutamentoInternoCandidato @relation(fields: [candidaturaId], references: [id], onDelete: Cascade)
  UsuarioChat                  UsuarioChat                  @relation(fields: [criadoPorId], references: [id])
}

model MotivosReprovacao {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome      String   @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @db.Timestamp(6)
}

enum Area {
  Sistemas
  Infra
}

enum TipoConversa {
  DIRETA
  GRUPO
}

enum TipoMensagem {
  TEXTO
  IMAGEM
  ARQUIVO
}

enum StatusMissao {
  RASCUNHO
  PUBLICADA
  ENCERRADA
  ARQUIVADA
}

enum StatusSubmissao {
  APROVADA
  REPROVADA
  EXCLUIDA
  PENDENTE
}

enum TipoMissao {
  UNICA
  DIARIA
  SEMANAL
}
