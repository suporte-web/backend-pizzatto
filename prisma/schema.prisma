generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Assinatura {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome          String
  telefone      String?
  email         String
  criadoPor     String
  caminhoImagem String?
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  updatedAt     DateTime @default(now()) @db.Timestamp(6)
  status        String?  @default("AGUARDANDO APROVAÇÃO")
  motivo        String?
  departamento  String
}

model ContasOffice {
  id    String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome  String
  email String
  senha String
  ativo Boolean @default(false)
}

model InventarioImpressoras {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  filial             String
  marca              String
  modelo             String
  numeroSerie        String?
  ip                 String
  macLan             String
  macWlan            String?
  localizacao        String?
  senhaAdministrador String?
  etiqueta           String?
  createdAt          DateTime @default(now()) @db.Timestamp(6)
  updatedAt          DateTime @default(now()) @db.Timestamp(6)
}

model Mural {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo              String
  mensagem            String
  caminhoImagem       String?
  filiais             String[]
  createdAt           DateTime          @default(now()) @db.Timestamp(6)
  updatedAt           DateTime          @default(now()) @db.Timestamp(6)
  ativo               Boolean           @default(true)
  validoAte           String?
  criadoPor           String
  importante          Boolean           @default(false)
  departamentoCriador String?
  MuralComentario     MuralComentario[]
  MuralLike           MuralLike[]
}

model Pops {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  filename     String
  originalName String
  mimetype     String
  size         String
  filePath     String
  folder       String
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @db.Timestamp(6)
  criadoPor    String?
  departamento String?
}

model ToDo {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome           String
  descricao      String
  prazoLimite    String?
  responsavel    String
  finalizado     Boolean  @default(false)
  dataFinalizado String?
  createdAt      DateTime @default(now()) @db.Timestamp(6)
  updatedAt      DateTime @default(now()) @db.Timestamp(6)
}

model audit_logs {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  acao           String
  entidade       String
  ipAddress      String?
  filialEntidade String?
  createdAt      DateTime @default(now())
}

model PlantaoConfig {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime        @default(now()) @db.Timestamp(6)
  updatedAt      DateTime        @default(now()) @db.Timestamp(6)
  dataJanela     String?
  janelaFim      String
  janelaInicio   String
  plantonistaId  String?         @db.Uuid
  status         String
  diaSemana      Int?
  PlantaoContato PlantaoContato? @relation(fields: [plantonistaId], references: [id])
}

model PlantaoContato {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome          String
  telefone      String
  area          Area
  createdAt     DateTime        @default(now()) @db.Timestamp(6)
  updatedAt     DateTime        @default(now()) @db.Timestamp(6)
  PlantaoConfig PlantaoConfig[]
}

model AssinaturaPadrao {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caminhoBackground    String?
  criadoPor            String?
  isAtual              Boolean  @default(true)
  createdAt            DateTime @default(now()) @db.Timestamp(6)
  updatedAt            DateTime @default(now()) @db.Timestamp(6)
  departamentoX        Int?
  departamentoY        Int?
  logoHeight           Int?
  logoX                Int?
  logoY                Int?
  nomeX                Int?
  nomeY                Int?
  photoSize            Int?
  photoX               Int?
  photoY               Int?
  telefoneX            Int?
  telefoneY            Int?
  departamentoCorFont  String?
  departamentoFontSize String?
  nomeCorFont          String?
  nomeFontSize         String?
  telefoneCorFont      String?
  telefoneFontSize     String?
}

model Calendario {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome          String
  data          String
  horario       String
  local         String?
  criadoPor     String?
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  updatedAt     DateTime @default(now()) @db.Timestamp(6)
  descricao     String?
  colaboradores String[]
}

model PoliticaAceites {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  colaborador String
  dataAceite  DateTime  @default(now())
  politicaId  String    @db.Uuid
  createdAt   DateTime  @default(now())
  Politicas   Politicas @relation(fields: [politicaId], references: [id])
}

model Politicas {
  id                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caminhoArquivo       String?
  nome                 String
  descricao            String
  responsavel          String
  dataUpload           String?
  criadoPor            String?
  ativo                Boolean           @default(true)
  liberadoVisualizacao Boolean           @default(false)
  createdAt            DateTime          @default(now()) @db.Timestamp(6)
  updatedAt            DateTime          @default(now()) @db.Timestamp(6)
  departamento         String
  tipoPolitica         String
  versao               String            @default("1")
  PoliticaAceites      PoliticaAceites[]
}

model MuralComentario {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  muralId    String   @db.Uuid
  codigo     String
  nome       String
  comentario String
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  updatedAt  DateTime @default(now()) @db.Timestamp(6)
  Mural      Mural    @relation(fields: [muralId], references: [id], onDelete: Cascade)

  @@index([muralId])
}

model MuralLike {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  muralId   String   @db.Uuid
  codigo    String
  nome      String
  createdAt DateTime @default(now()) @db.Timestamp(6)
  Mural     Mural    @relation(fields: [muralId], references: [id], onDelete: Cascade)

  @@unique([muralId, codigo])
  @@index([muralId])
}

model PaginaInstitucional {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo          String
  descricao       String
  caminhoImagem   String[]
  dataAtualizacao String
  createdAt       DateTime @default(now()) @db.Timestamp(6)
  updatedAt       DateTime @default(now()) @db.Timestamp(6)
  status          Boolean  @default(true)
}

model BibliotecaMarca {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome           String
  caminhoArquivo String?
  status         Boolean  @default(true)
  descricao      String
  createdAt      DateTime @default(now()) @db.Timestamp(6)
  updatedAt      DateTime @default(now()) @db.Timestamp(6)
}

model Conversa {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipo                 TipoConversa
  nome                 String?
  chaveDireta          String?                @unique
  criadoPorId          String                 @db.Uuid
  ultimaMensagemEm     DateTime?
  createdAt            DateTime               @default(now()) @db.Timestamp(6)
  updatedAt            DateTime               @default(now()) @db.Timestamp(6)
  UsuarioChat          UsuarioChat            @relation(fields: [criadoPorId], references: [id])
  Mensagem             Mensagem[]
  ParticipanteConversa ParticipanteConversa[]

  @@index([criadoPorId])
  @@index([tipo])
  @@index([ultimaMensagemEm])
}

model Mensagem {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversaId   String       @db.Uuid
  remetenteId  String       @db.Uuid
  conteudo     String?
  createdAt    DateTime     @default(now()) @db.Timestamp(6)
  deletedAt    DateTime?
  updatedAt    DateTime     @default(now()) @db.Timestamp(6)
  arquivoUrl   String?
  mimeType     String?
  nomeArquivo  String?
  tamanhoBytes Int?
  tipo         TipoMensagem @default(TEXTO)
  nomeSalvo    String?
  Conversa     Conversa     @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  UsuarioChat  UsuarioChat  @relation(fields: [remetenteId], references: [id])

  @@index([remetenteId])
  @@index([conversaId, createdAt])
}

model ParticipanteConversa {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversaId      String      @db.Uuid
  usuarioId       String      @db.Uuid
  entrouEm        DateTime    @default(now())
  ultimaLeituraEm DateTime?
  admin           Boolean     @default(false)
  createdAt       DateTime    @default(now()) @db.Timestamp(6)
  updatedAt       DateTime    @default(now()) @db.Timestamp(6)
  Conversa        Conversa    @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  UsuarioChat     UsuarioChat @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([conversaId, usuarioId])
  @@index([conversaId])
  @@index([usuarioId])
}

model UsuarioChat {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adObjectGuid         String                 @unique
  usuario              String
  nome                 String
  email                String?
  empresa              String?
  departamento         String?
  telefone             String?
  ativo                Boolean                @default(true)
  createdAt            DateTime               @default(now()) @db.Timestamp(6)
  updatedAt            DateTime               @default(now()) @db.Timestamp(6)
  Conversa             Conversa[]
  Mensagem             Mensagem[]
  ParticipanteConversa ParticipanteConversa[]

  @@index([email])
  @@index([nome])
  @@index([usuario])
}

enum Area {
  Sistemas
  Infra
}

enum TipoConversa {
  DIRETA
  GRUPO
}

enum TipoMensagem {
  TEXTO
  IMAGEM
  ARQUIVO
}
